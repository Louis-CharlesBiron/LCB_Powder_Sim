{
    "packageJsonPath": "../codeBuilds/package.json",
    "projectName": "lcb-powder-sim",

    "projectRoot": "../../",
    "srcRoot": "src",
    "distRoot": "deployements/codeBuilds",

    "readmePath": "readme.md",
    "licensePath": "LICENSE",
    "npmVersionedFilePaths": ["readme.md"],

    "dtsFolderName": "dts",
    "binsFolderName": "bins",
    "UMDFolderName": "umd",
    "ESMFolderName": "esm",
    "unminifiedFolderName": "raw",
    "buildNameUMD": "lcbPS",
    "buildNameESM": "lcb-ps",

    "mergeOrder": [
        "[*]canvasDotEffect.js",
        "[%]cde.js",
        "warnings.js",
        "CameraManager.js",
        "SimUtils.js",
        "KeybindManager.js",
        "settings.js",
        "colorSettings.js",
        "userSettings.js",
        "worldStartSettings.js",
        "physicsSettings.js",
        "MaterialsSettings.js",
        "defaultKeybinds.js",
        "PhysicsUtils.js",
        "MaterialsBehavior.js",
        "PhysicsCore.js",
        "PhysicsCoreWorker.js",
        "_PhysicsUnit.js",
        "LocalPhysicsUnit.js",
        "RemotePhysicsUnit.js",
        "MapGrid.js",
        "Simulation.js"
    ],
    "UMDExpose": [
        "Simulation",
        "FPSCounter",
        "CDEUtils",
        "SimUtils",
        "createPhysicsCoreWorker",
        "Color",
        "Canvas"
    ],
    "dependencies": [],
    "workers":[
        {
            "file": "RemotePhysicsWorker.js",
            "importExpressions": ["createPhysicsCoreWorker"]
        }
    ],
    "workerMocks": ["DOMParser", "IntersectionObserver", "HTMLVideoElement", "HTMLAudioElement", "SVGImageElement", "HTMLImageElement", "HTMLCanvasElement", "document"],
    "verisonedFiles": [],
    "srcExtensions": [".js"]
}